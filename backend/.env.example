# ==================================
# UBER-Clone Backend — Environment
# ==================================

# Server
PORT=8000
NODE_ENV=development
SERVICE_NAME=uber-backend

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/uber

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secrets (use strong random values in production)
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# Cookie Secret (use strong random value in production)
COOKIE_SECRET=your_cookie_secret_here

# CORS
CORS_ORIGIN=http://localhost:3000

# Metrics (set in production to protect /metrics endpoint)
# METRICS_TOKEN=your_metrics_bearer_token_here

# Kafka (comma-separated broker list)
KAFKA_BROKERS=localhost:9092

# Frontend
FRONTEND_URL=http://localhost:3000
